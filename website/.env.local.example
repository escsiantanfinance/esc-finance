# ── Supabase (wajib) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service-role key — HANYA dipakai server (API backup/restore). JANGAN diekspos ke client.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Backup & Recovery ─────────────────────────────────────
# Kunci enkripsi file cadangan (AES-256). Pakai string acak panjang & rahasia.
BACKUP_ENCRYPTION_KEY=ganti-dengan-kunci-rahasia-panjang
# Secret untuk melindungi endpoint cron /api/backup/scheduled
CRON_SECRET=ganti-dengan-secret-cron
